# --- Platform selection (default: fantrax) ---
# PLATFORM=fantrax        # use Fantrax — required env vars: FANTRAX_*
# PLATFORM=espn           # use ESPN (waivers command only) — required env vars: ESPN_*

# --- Fantrax credentials (required when PLATFORM=fantrax) ---
FANTRAX_USERNAME=you@example.com
FANTRAX_PASSWORD=yourpassword
FANTRAX_LEAGUE_ID=your_league_id
FANTRAX_TEAM_ID=your_team_id
FANTRAX_IL_SLOTS=6
FANTRAX_MINORS_SLOTS=10

# --- ESPN credentials (required when PLATFORM=espn) ---
# Grab SWID + espn_s2 from your logged-in browser:
#   Chrome → DevTools → Application → Cookies → https://fantasy.espn.com
# SWID includes the curly braces.
# ESPN_LEAGUE_ID=12345
# ESPN_TEAM_ID=7
# ESPN_YEAR=                          # blank = current calendar year
# ESPN_SWID={ABCDEF12-3456-7890-...}
# ESPN_S2=AEAlongbase64stringfromcookie...

# --- Optional / shared ---
GS_MAX=12
GS_MIN=7
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=
PUSHOVER_GROUP_KEY=
